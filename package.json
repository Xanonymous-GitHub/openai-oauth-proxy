{
  "name": "openai-oauth-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:server": "tsc -p tsconfig.build.json",
    "build:admin": "tsc -p tsconfig.admin.json --noEmit && vite build",
    "build": "bun run build:server && bun run build:admin",
    "typecheck:server": "tsc -p tsconfig.json --noEmit",
    "typecheck:admin": "tsc -p tsconfig.admin.json --noEmit",
    "typecheck": "bun run typecheck:server && bun run typecheck:admin",
    "test": "vitest run",
    "check": "biome check . && bun run typecheck && bun run test && bun run build",
    "start": "node dist/main.js",
    "deps:check": "bunx npm-check-updates --errorLevel 2",
    "protocol:generate": "mkdir -p src/codex/generated && codex app-server generate-ts --experimental --out src/codex/generated && codex app-server generate-json-schema --experimental --out src/codex/generated",
    "postprotocol:generate": "node -e \"const fs=require('node:fs');const sort=(value)=>Array.isArray(value)?value.map(sort):value&&typeof value==='object'?Object.fromEntries(Object.entries(value).sort(([a],[b])=>a.localeCompare(b)).map(([key,item])=>[key,sort(item)])):value;for(const file of ['src/codex/generated/codex_app_server_protocol.schemas.json','src/codex/generated/codex_app_server_protocol.v2.schemas.json'])fs.writeFileSync(file,JSON.stringify(sort(JSON.parse(fs.readFileSync(file,'utf8'))),null,2)+'\\n')\"",
    "protocol:check": "bun run protocol:generate && git diff --exit-code -- src/codex/generated"
  },
  "dependencies": {
    "@hono/node-server": "2.0.10",
    "@openai/codex": "0.144.5",
    "hono": "4.12.30",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@fontsource-variable/geist": "5.2.9",
    "@fontsource-variable/geist-mono": "5.2.8",
    "@tabler/icons-react": "3.45.0",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "ajv": "8.20.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "jsdom": "29.1.1",
    "npm-check-updates": "22.2.9",
    "openai": "6.48.0",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "4.13.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
